<script>
    // إعدادات المستودع الخاصة بك - TECHNO INFODZ
    const GITHUB_USER = 'samirinfodz-boop';
    const REPO_NAME = 'technoinfodz-official';
    const FILE_PATH = 'products.json'; // الملف الذي سيخزن المنتجات
    let GITHUB_TOKEN = localStorage.getItem('gh_token') || '';

    let products = [];
    let clickCount = 0;

    // 1. تفعيل وضع الإدارة بالضغط 5 مرات على الشعار
    function handleAdminClick() {
        clickCount++;
        if (clickCount === 5) {
            const pass = prompt("أدخل رمز الوصول (TOKEN):", GITHUB_TOKEN);
            if (pass) {
                GITHUB_TOKEN = pass;
                localStorage.setItem('gh_token', pass);
                document.body.classList.add('is-admin');
                alert("تم تفعيل وضع الإدارة بنجاح لعلامة TECHNO INFODZ!");
                location.reload(); // تحديث لإظهار الأزرار
            }
            clickCount = 0;
        }
    }

    // تفعيل الوضع تلقائياً إذا كان التوكن مخزناً
    if (GITHUB_TOKEN) { document.body.classList.add('is-admin'); }

    // 2. دالة جلب المنتجات من GitHub وعرضها للزوار
    async function loadProducts() {
        try {
            const response = await fetch(`https://raw.githubusercontent.com/${GITHUB_USER}/${REPO_NAME}/main/${FILE_PATH}`);
            if (response.ok) {
                products = await response.json();
                renderProducts();
            }
        } catch (error) { console.error("خطأ في تحميل المنتجات:", error); }
    }

    function renderProducts() {
        const grid = document.getElementById('products-grid');
        grid.innerHTML = products.map((p, index) => `
            <div class="bg-white p-4 rounded-xl shadow-md border hover:shadow-xl transition-all relative">
                <img src="${p.image || 'https://via.placeholder.com/150'}" class="w-full h-40 object-contain mb-4">
                <h3 class="font-bold text-lg text-blue-900">${p.name}</h3>
                <p class="text-green-600 font-bold mt-2">${p.price} دج</p>
                <span class="text-xs bg-gray-100 px-2 py-1 rounded mt-2 inline-block">${p.category}</span>
                
                <div class="admin-only mt-4 flex gap-2">
                    <button onclick="deleteProduct(${index})" class="bg-red-500 text-white p-2 rounded hover:bg-red-600 flex-1">
                        <i class="fas fa-trash"></i> حذف
                    </button>
                </div>
            </div>
        `).join('');
    }

    // 3. دالة إضافة منتج جديد (تفعيل زر الإضافة)
    async function showAddModal() {
        if (!GITHUB_TOKEN) { alert("يرجى تفعيل وضع الإدارة أولاً!"); return; }
        
        const name = prompt("اسم المنتج (مثال: طابعة حرارية):");
        const price = prompt("السعر بالدينار:");
        const category = prompt("الصنف (HENEX / SMART / SOFTWARE):");
        const image = prompt("رابط صورة المنتج (يمكنك رفعه على GitHub ومسح الرابط هنا):");

        if (name && price) {
            const newProduct = { name, price, category, image };
            products.push(newProduct);
            await saveToGitHub("إضافة منتج جديد: " + name);
        }
    }

    // 4. دالة الحذف
    async function deleteProduct(index) {
        if (confirm("هل أنت متأكد من حذف هذا المنتج؟")) {
            const removed = products.splice(index, 1);
            await saveToGitHub("حذف منتج: " + removed[0].name);
        }
    }

    // 5. المحرك الأساسي: حفظ التعديلات في مستودع GitHub فوراً
    async function saveToGitHub(message) {
        const url = `https://api.github.com/repos/${GITHUB_USER}/${REPO_NAME}/contents/${FILE_PATH}`;
        
        try {
            // جلب ملف الـ SHA (ضروري للتحديث في GitHub)
            const res = await fetch(url, { headers: { 'Authorization': `token ${GITHUB_TOKEN}` } });
            const data = await res.json();
            const sha = data.sha;

            const content = btoa(unescape(encodeURIComponent(JSON.stringify(products, null, 2))));

            const putRes = await fetch(url, {
                method: 'PUT',
                headers: { 'Authorization': `token ${GITHUB_TOKEN}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({ message, content, sha })
            });

            if (putRes.ok) {
                alert("تم التحديث بنجاح على GitHub!");
                location.reload();
            } else { alert("فشل التحديث. تأكد من صحة الـ TOKEN."); }
        } catch (error) { console.error("Error:", error); }
    }

    // تشغيل الجلب عند فتح الموقع
    loadProducts();
</script>
